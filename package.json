{
  "name": "hippo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "hippo": "./bin/hippo.js"
  },
  "description": "Durable workflow engine with Postgres-backed execution state",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "hippo:dev": "tsx scripts/hippo-dev.ts",
    "hippo:init": "node ./bin/hippo.js init",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "dbmate up",
    "db:new": "dbmate new",
    "pgtyped": "npx pgtyped -c pgtyped-config.json",
    "render:demo": "tsx scripts/render-demo.ts"
  },
  "dependencies": {
    "@fastify/sensible": "6.0.3",
    "@pgtyped/runtime": "2.4.2",
    "cron-parser": "^5.6.0",
    "fastify": "5.6.0",
    "pg": "8.16.3",
    "prom-client": "15.1.3",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@pgtyped/cli": "2.4.3",
    "@types/node": "24.3.1",
    "@types/pg": "8.15.5",
    "@typescript-eslint/eslint-plugin": "8.42.0",
    "@typescript-eslint/parser": "8.42.0",
    "dbmate": "2.29.0",
    "eslint": "9.35.0",
    "tsx": "4.20.3",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  }
}
