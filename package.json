{
  "name": "hippo",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "exports": {
    "./core": "./dist/src/core.js",
    "./sdk": "./dist/src/sdk.js",
    "./server": "./dist/src/server.js"
  },
  "bin": {
    "hippo": "./bin/hippo.js"
  },
  "description": "Durable workflow engine with Postgres-backed execution state",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blairjordan/pygmyhippo.git"
  },
  "homepage": "https://github.com/blairjordan/pygmyhippo#readme",
  "bugs": {
    "url": "https://github.com/blairjordan/pygmyhippo/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "hippo:dev": "tsx scripts/hippo-dev.ts",
    "hippo:init": "tsx src/cli.ts init",
    "start": "node dist/src/index.js",
    "build": "node scripts/generate-migrations.mjs && npm run build:css && tsc -p tsconfig.json && npm run build:packages",
    "build:packages": "npm run build --workspace=pygmyhippo-core && npm run build --workspace=pygmyhippo-sdk && npm run build --workspace=pygmyhippo-hermes && npm run build --workspace=pygmyhippo-server && npm run build --workspace=pygmyhippo-cli",
    "build:css": "tailwindcss -i src/views/dashboard/input.css -o src/views/dashboard/styles.css && mkdir -p dist/src/views/dashboard && cp src/views/dashboard/styles.css dist/src/views/dashboard/styles.css",
    "bench:throughput": "npx tsx bench/throughput.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --exclude 'src/.reload-*/**'",
    "test:pg": "vitest run --exclude 'src/.reload-*/**' src/lib/workflow-store.*.pg.test.ts",
    "test:watch": "vitest --exclude 'src/.reload-*/**'",
    "db:migrate": "dbmate up",
    "db:new": "dbmate new",
    "pgtyped": "npx pgtyped -c pgtyped-config.json",
    "render:demo": "tsx scripts/render-demo.ts",
    "test:public-api": "npm run build && node scripts/verify-public-api.mjs",
    "test:hermes-registry": "node scripts/verify-hermes-registry-install.mjs",
    "test:hermes-runner": "python3 -m unittest examples/hermes-runner/test_runner.py"
  },
  "dependencies": {
    "@fastify/sensible": "6.0.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@pgtyped/runtime": "2.4.2",
    "commander": "^15.0.0",
    "cron-parser": "^5.6.0",
    "fastify": "5.6.0",
    "pg": "8.16.3",
    "prom-client": "15.1.3",
    "pygmyhippo-hermes": "0.1.1",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@dbmate/linux-x64": "^2.33.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@pgtyped/cli": "2.4.3",
    "@types/node": "24.3.1",
    "@types/pg": "8.15.5",
    "@typescript-eslint/eslint-plugin": "8.42.0",
    "@typescript-eslint/parser": "8.42.0",
    "dbmate": "2.29.0",
    "eslint": "9.35.0",
    "tailwindcss": "^3.4.17",
    "tsx": "4.20.3",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  }
}
